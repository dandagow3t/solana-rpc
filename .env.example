# Provider API keys -- set once, referenced by name below
HELIUS_API_KEY=your-helius-api-key
ALCHEMY_API_KEY=your-alchemy-api-key

# SolanaRpcBuilder -- config-driven RPC provider selection
# Used by SolanaRpcBuilder::from_env()
# API keys are resolved from the provider name (e.g. helius → HELIUS_API_KEY)
PRIMARY_PROVIDER=helius
# Optional: set to enable automatic RPC failover
# SECONDARY_PROVIDER=alchemy

# WsClientBuilder -- independent WebSocket provider selection
# Used by WsClientBuilder::from_env()
# WS providers can differ from RPC providers (e.g. RPC=Helius, WS=Alchemy)
WS_PRIMARY_PROVIDER=helius
# Optional: set to enable per-subscription WS failover
# WS_SECONDARY_PROVIDER=alchemy
